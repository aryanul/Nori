# ──────────────────────────────────────────────────────────────
# Nori environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this file (`.env.example`) is committed.
# ──────────────────────────────────────────────────────────────

# ── Database (MongoDB Atlas) ──────────────────────────────────
# Atlas → Database → Connect → Drivers → Node.js. Include the db name.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/nori?retryWrites=true&w=majority
MONGODB_URI=

# ── Auth (NextAuth / Auth.js v5) ──────────────────────────────
# Generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Optional in dev — defaults to http://localhost:3000.
# AUTH_URL=http://localhost:3000

# GitHub OAuth app — create one at https://github.com/settings/developers
# Homepage URL:            http://localhost:3000
# Authorization callback:  http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app — create one at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000
# Authorized redirect URIs:      http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── File storage (Cloudinary or UploadThing) — added later ────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# UPLOADTHING_TOKEN=

# ── Realtime (Hocuspocus) ─────────────────────────────────────
# Default port the Hocuspocus sync server listens on. Used by
# `npm run hocuspocus`.
HOCUSPOCUS_PORT=1234

# WebSocket URL the browser uses to reach the Hocuspocus server.
# In dev, the server runs on the same machine on the port above.
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
