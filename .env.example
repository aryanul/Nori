# ──────────────────────────────────────────────────────────────
# Nori environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this file (`.env.example`) is committed.
# ──────────────────────────────────────────────────────────────

# ── Database (MongoDB Atlas) ──────────────────────────────────
# Atlas → Database → Connect → Drivers → Node.js. Include the db name.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/nori?retryWrites=true&w=majority
MONGODB_URI=

# ── Auth (NextAuth / Auth.js v5) — added in a later slice ─────
# Generate a secret with: openssl rand -base64 32
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (https://github.com/settings/developers)
# GITHUB_ID=
# GITHUB_SECRET=

# ── File storage (Cloudinary or UploadThing) — added later ────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# UPLOADTHING_TOKEN=

# ── Realtime (Hocuspocus) — added later, optional ─────────────
# When unset, the client falls back to y-webrtc (P2P, no server).
# NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
